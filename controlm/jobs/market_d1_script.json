    "B3_close_market_eod": {
      "Type": "Job:Script",
      "FileName": "run_job.py",
      "FilePath": "%%SCRIPT_DIR%%",
      "Arguments": "--job close_market_eod --date %%ODATE%%",
      "Command": "%%PYTHON_BIN%% %%SCRIPT_DIR%%%%PATH_SEP%%run_job.py --job close_market_eod --date %%ODATE%%",
      "Host": "%%CTM_AGENT_HOST%%",
      "RunAs": "%%RUN_AS%%",
      "Description": "EOD market close — consolidates book, calculates closing prices and VWAP",
      "SLA": {
        "Duration": "00:10"
      }
    },
    "B3_reconcile_d1_positions": {
      "Type": "Job:Script",
      "FileName": "run_job.py",
      "FilePath": "%%SCRIPT_DIR%%",
      "Arguments": "--job reconcile_d1_positions --date %%ODATE%%",
      "Command": "%%PYTHON_BIN%% %%SCRIPT_DIR%%%%PATH_SEP%%run_job.py --job reconcile_d1_positions --date %%ODATE%%",
      "Host": "%%CTM_AGENT_HOST%%",
