      "Command": "%%PYTHON_BIN%% %%SCRIPT_DIR%%%%PATH_SEP%%run_job.py --job quality_gate_d1 --date %%ODATE%%",
      "Host": "%%CTM_AGENT_HOST%%",
      "RunAs": "%%RUN_AS%%",
      "Description": "D+1 quality gate — completeness, uniqueness, consistency, reasonableness, timeliness",
      "SLA": {
        "Duration": "00:05"
      },
      "DependsOn": [
        {
          "Name": "B3_reconcile_d1_positions",
          "State": "OK"
        }
      ]
    },
    "B3_publish_d1_reports": {
      "Type": "Job:Script",
      "FileName": "run_job.py",
      "FilePath": "%%SCRIPT_DIR%%",
