        {
          "Name": "B3_close_market_eod",
          "State": "OK"
        }
      ]
    },
    "B3_quality_gate_d1": {
      "Type": "Job:Script",
      "FileName": "run_job.py",
      "FilePath": "%%SCRIPT_DIR%%",
